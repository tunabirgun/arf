{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arf",
  "version": "1.3.0",
  "identifier": "io.github.tunabirgun.arf",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5175",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Arf",
        "width": 1200,
        "height": 820,
        "center": true,
        "resizable": true,
        "minWidth": 720,
        "minHeight": 480,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "A second brain for scientists",
    "longDescription": "Arf is a local-first second brain for scientists and coders: notes, bidirectional links, a knowledge graph, and a private on-device machine that suggests connections.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
